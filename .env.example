# Discord 設定
DISCORD_TOKEN=your_token_here
DISCORD_LOG_CHANNEL_NAME=ClawSporeLog

# 無反応時間が続いた場合に AI が話題を振るまでの時間（時間単位）
DISCORD_INACTIVITY_THRESHOLD_HOURS=12

# セキュリティ設定 (危険な操作の制限) 管理者のDiscordユーザーIDを設定してください
ADMIN_DISCORD_USER_ID=123456789012345678

LM_STUDIO_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=gemma-3-4b-it
LM_STUDIO_MODEL=qwen/qwen3.5-9b

# Podman Limbs 隔離環境設定
PODMAN_SOCKET=ssh://core@host.containers.internal:49441/run/user/501/podman/podman.sock
PODMAN_SSH_KEY=your_ssh_private_key_content_here

GEMINI_API_KEY=あなたのAPIキー
GEMINI_MODEL=gemini-3-flash-preview

